# Optional: defaults to ~/.jarvis/vault. Keep personal data outside this repository.
JARVIS_VAULT_DIR=

# Explicit compatibility escape hatch. Never enable in a public clone you plan to commit.
JARVIS_LEGACY_REPO_MEMORY=0

# GitHub (for bootstrap)
GITHUB_USERNAME=your-username
GITHUB_TOKEN=

# Optional standard proxy for model downloads
HTTPS_PROXY=
